{
  "$defs": {
    "ImagePlanItem": {
      "additionalProperties": false,
      "properties": {
        "imageType": {
          "enum": [
            "background",
            "course_review_atmosphere",
            "business_scene",
            "classical_element",
            "thesis_concept",
            "product_showcase",
            "icon_illustration",
            "data_visual"
          ],
          "title": "Imagetype",
          "type": "string"
        },
        "needsImage": {
          "title": "Needsimage",
          "type": "boolean"
        },
        "prompt": {
          "minLength": 1,
          "pattern": "\\S",
          "title": "Prompt",
          "type": "string"
        },
        "providerChain": {
          "items": {
            "enum": [
              "open_web_search",
              "OpenAI Image API",
              "Pollinations FLUX API",
              "Midjourney API",
              "Stable Diffusion API",
              "custom image2 API",
              "local_png_fallback"
            ],
            "type": "string"
          },
          "maxItems": 7,
          "minItems": 1,
          "title": "Providerchain",
          "type": "array"
        },
        "purpose": {
          "minLength": 1,
          "pattern": "\\S",
          "title": "Purpose",
          "type": "string"
        },
        "schemaVersion": {
          "const": "1.0.0",
          "title": "Schemaversion",
          "type": "string"
        },
        "searchQuery": {
          "minLength": 1,
          "pattern": "\\S",
          "title": "Searchquery",
          "type": "string"
        },
        "slide": {
          "minimum": 1,
          "title": "Slide",
          "type": "integer"
        }
      },
      "required": [
        "schemaVersion",
        "slide",
        "needsImage",
        "imageType",
        "prompt",
        "purpose",
        "searchQuery",
        "providerChain"
      ],
      "title": "ImagePlanItem",
      "type": "object"
    },
    "SlideBlock": {
      "additionalProperties": false,
      "properties": {
        "blockId": {
          "minLength": 1,
          "pattern": "\\S",
          "title": "Blockid",
          "type": "string"
        },
        "blockType": {
          "enum": [
            "headline",
            "subtitle",
            "body",
            "card",
            "chart_placeholder",
            "image_placeholder",
            "speaker_notes"
          ],
          "title": "Blocktype",
          "type": "string"
        },
        "content": {
          "minLength": 1,
          "pattern": "\\S",
          "title": "Content",
          "type": "string"
        },
        "role": {
          "minLength": 1,
          "pattern": "\\S",
          "title": "Role",
          "type": "string"
        },
        "schemaVersion": {
          "const": "1.0.0",
          "title": "Schemaversion",
          "type": "string"
        }
      },
      "required": [
        "schemaVersion",
        "blockId",
        "blockType",
        "content",
        "role"
      ],
      "title": "SlideBlock",
      "type": "object"
    },
    "SlideDeckSlide": {
      "additionalProperties": false,
      "properties": {
        "blocks": {
          "items": {
            "$ref": "#/$defs/SlideBlock"
          },
          "maxItems": 12,
          "minItems": 2,
          "title": "Blocks",
          "type": "array"
        },
        "designPlan": {
          "$ref": "#/$defs/SlideDesignPlan"
        },
        "layout": {
          "minLength": 1,
          "pattern": "\\S",
          "title": "Layout",
          "type": "string"
        },
        "purpose": {
          "enum": [
            "cover",
            "agenda",
            "context",
            "insight",
            "evidence",
            "framework",
            "recommendation",
            "conclusion"
          ],
          "title": "Purpose",
          "type": "string"
        },
        "schemaVersion": {
          "const": "1.0.0",
          "title": "Schemaversion",
          "type": "string"
        },
        "slideId": {
          "minLength": 1,
          "pattern": "\\S",
          "title": "Slideid",
          "type": "string"
        },
        "slideIndex": {
          "minimum": 1,
          "title": "Slideindex",
          "type": "integer"
        },
        "speakerNotes": {
          "minLength": 1,
          "pattern": "\\S",
          "title": "Speakernotes",
          "type": "string"
        },
        "subtitle": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Subtitle"
        },
        "title": {
          "minLength": 1,
          "pattern": "\\S",
          "title": "Title",
          "type": "string"
        },
        "visualIntent": {
          "minLength": 1,
          "pattern": "\\S",
          "title": "Visualintent",
          "type": "string"
        }
      },
      "required": [
        "schemaVersion",
        "slideId",
        "slideIndex",
        "title",
        "purpose",
        "layout",
        "visualIntent",
        "designPlan",
        "blocks",
        "speakerNotes"
      ],
      "title": "SlideDeckSlide",
      "type": "object"
    },
    "SlideDeckTheme": {
      "additionalProperties": false,
      "properties": {
        "designSeed": {
          "maximum": 2147483647,
          "minimum": 0,
          "title": "Designseed",
          "type": "integer"
        },
        "designSystemId": {
          "minLength": 1,
          "pattern": "\\S",
          "title": "Designsystemid",
          "type": "string"
        },
        "directionId": {
          "enum": [
            "apple",
            "mckinsey",
            "airbnb",
            "academic_clean",
            "thesis_blue",
            "research_journal",
            "startup_pitch",
            "investor_dark",
            "classroom_friendly",
            "data_story",
            "editorial_magazine",
            "glassmorphism",
            "medical_science",
            "cinematic_research",
            "policy_brief",
            "ink_classical",
            "product_showcase",
            "architectural_premium",
            "finance_terminal",
            "workshop_playbook"
          ],
          "title": "Directionid",
          "type": "string"
        },
        "layoutPrinciples": {
          "items": {
            "minLength": 1,
            "pattern": "\\S",
            "type": "string"
          },
          "maxItems": 8,
          "minItems": 3,
          "title": "Layoutprinciples",
          "type": "array"
        },
        "name": {
          "minLength": 1,
          "pattern": "\\S",
          "title": "Name",
          "type": "string"
        },
        "palette": {
          "items": {
            "minLength": 1,
            "pattern": "\\S",
            "type": "string"
          },
          "maxItems": 8,
          "minItems": 3,
          "title": "Palette",
          "type": "array"
        },
        "schemaVersion": {
          "const": "1.0.0",
          "title": "Schemaversion",
          "type": "string"
        },
        "textureLayer": {
          "minLength": 1,
          "pattern": "\\S",
          "title": "Texturelayer",
          "type": "string"
        },
        "typography": {
          "minLength": 1,
          "pattern": "\\S",
          "title": "Typography",
          "type": "string"
        }
      },
      "required": [
        "schemaVersion",
        "directionId",
        "name",
        "palette",
        "typography",
        "textureLayer",
        "layoutPrinciples",
        "designSystemId",
        "designSeed"
      ],
      "title": "SlideDeckTheme",
      "type": "object"
    },
    "SlideDesignPlan": {
      "additionalProperties": false,
      "properties": {
        "assetQuery": {
          "minLength": 1,
          "pattern": "\\S",
          "title": "Assetquery",
          "type": "string"
        },
        "assetRole": {
          "enum": [
            "hero",
            "context",
            "evidence",
            "diagram",
            "metaphor",
            "portrait"
          ],
          "title": "Assetrole",
          "type": "string"
        },
        "compositionArchetype": {
          "enum": [
            "cinematic_hero",
            "editorial_cover",
            "architectural_cover",
            "chapter_index",
            "editorial_split",
            "diagonal_story",
            "statement_focus",
            "proof_mosaic",
            "data_landscape",
            "process_ribbon",
            "system_map",
            "split_comparison",
            "priority_stack",
            "closing_echo",
            "manifesto_close",
            "future_horizon"
          ],
          "title": "Compositionarchetype",
          "type": "string"
        },
        "compositionVariant": {
          "minLength": 1,
          "pattern": "\\S",
          "title": "Compositionvariant",
          "type": "string"
        },
        "contentDensity": {
          "enum": [
            "sparse",
            "balanced",
            "dense"
          ],
          "title": "Contentdensity",
          "type": "string"
        },
        "diagramLabels": {
          "items": {
            "maxLength": 64,
            "minLength": 1,
            "pattern": "\\S",
            "type": "string"
          },
          "maxItems": 4,
          "minItems": 2,
          "title": "Diagramlabels",
          "type": "array"
        },
        "explanationMode": {
          "enum": [
            "hero_photo",
            "concept_diagram",
            "process_diagram",
            "data_evidence",
            "comparison_visual",
            "annotated_image",
            "summary_map"
          ],
          "title": "Explanationmode",
          "type": "string"
        },
        "hierarchy": {
          "items": {
            "minLength": 1,
            "pattern": "\\S",
            "type": "string"
          },
          "maxItems": 8,
          "minItems": 3,
          "title": "Hierarchy",
          "type": "array"
        },
        "imageTreatment": {
          "enum": [
            "full_bleed",
            "split_crop",
            "masked_window",
            "layered_cutout",
            "evidence_strip",
            "atmospheric_backdrop"
          ],
          "title": "Imagetreatment",
          "type": "string"
        },
        "motionPreset": {
          "enum": [
            "cinematic_reveal",
            "editorial_wipe",
            "depth_parallax",
            "evidence_reveal",
            "sequence_build",
            "diagram_orbit",
            "closing_resolve"
          ],
          "title": "Motionpreset",
          "type": "string"
        },
        "rationale": {
          "minLength": 1,
          "pattern": "\\S",
          "title": "Rationale",
          "type": "string"
        },
        "schemaVersion": {
          "const": "1.0.0",
          "title": "Schemaversion",
          "type": "string"
        },
        "visualBrief": {
          "minLength": 1,
          "pattern": "\\S",
          "title": "Visualbrief",
          "type": "string"
        },
        "visualLayers": {
          "items": {
            "minLength": 1,
            "pattern": "\\S",
            "type": "string"
          },
          "maxItems": 8,
          "minItems": 3,
          "title": "Visuallayers",
          "type": "array"
        }
      },
      "required": [
        "schemaVersion",
        "compositionArchetype",
        "compositionVariant",
        "imageTreatment",
        "assetRole",
        "assetQuery",
        "contentDensity",
        "hierarchy",
        "visualLayers",
        "explanationMode",
        "visualBrief",
        "diagramLabels",
        "motionPreset",
        "rationale"
      ],
      "title": "SlideDesignPlan",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "exportTargets": {
      "items": {
        "enum": [
          "pptx",
          "hyperframes_html"
        ],
        "type": "string"
      },
      "maxItems": 2,
      "minItems": 2,
      "title": "Exporttargets",
      "type": "array"
    },
    "imagePlan": {
      "items": {
        "$ref": "#/$defs/ImagePlanItem"
      },
      "maxItems": 30,
      "minItems": 3,
      "title": "Imageplan",
      "type": "array"
    },
    "language": {
      "enum": [
        "zh",
        "en",
        "bilingual"
      ],
      "title": "Language",
      "type": "string"
    },
    "outlineVersion": {
      "minimum": 1,
      "title": "Outlineversion",
      "type": "integer"
    },
    "projectId": {
      "minLength": 1,
      "pattern": "\\S",
      "title": "Projectid",
      "type": "string"
    },
    "schemaVersion": {
      "const": "1.0.0",
      "title": "Schemaversion",
      "type": "string"
    },
    "slides": {
      "items": {
        "$ref": "#/$defs/SlideDeckSlide"
      },
      "maxItems": 30,
      "minItems": 3,
      "title": "Slides",
      "type": "array"
    },
    "theme": {
      "$ref": "#/$defs/SlideDeckTheme"
    },
    "title": {
      "minLength": 1,
      "pattern": "\\S",
      "title": "Title",
      "type": "string"
    },
    "visualDirectionVersion": {
      "minimum": 1,
      "title": "Visualdirectionversion",
      "type": "integer"
    }
  },
  "required": [
    "schemaVersion",
    "projectId",
    "outlineVersion",
    "visualDirectionVersion",
    "language",
    "title",
    "theme",
    "slides",
    "imagePlan",
    "exportTargets"
  ],
  "title": "SlideDeck",
  "type": "object"
}
