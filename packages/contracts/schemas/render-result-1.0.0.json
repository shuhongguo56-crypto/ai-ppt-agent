{
  "$defs": {
    "RenderArtifact": {
      "additionalProperties": false,
      "properties": {
        "contentType": {
          "minLength": 1,
          "pattern": "\\S",
          "title": "Contenttype",
          "type": "string"
        },
        "path": {
          "minLength": 1,
          "pattern": "\\S",
          "title": "Path",
          "type": "string"
        },
        "schemaVersion": {
          "const": "1.0.0",
          "title": "Schemaversion",
          "type": "string"
        },
        "slideCount": {
          "minimum": 1,
          "title": "Slidecount",
          "type": "integer"
        },
        "target": {
          "enum": [
            "pptx",
            "hyperframes_html"
          ],
          "title": "Target",
          "type": "string"
        }
      },
      "required": [
        "schemaVersion",
        "target",
        "path",
        "contentType",
        "slideCount"
      ],
      "title": "RenderArtifact",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "artifacts": {
      "items": {
        "$ref": "#/$defs/RenderArtifact"
      },
      "maxItems": 2,
      "minItems": 2,
      "title": "Artifacts",
      "type": "array"
    },
    "projectId": {
      "minLength": 1,
      "pattern": "\\S",
      "title": "Projectid",
      "type": "string"
    },
    "schemaVersion": {
      "const": "1.0.0",
      "title": "Schemaversion",
      "type": "string"
    },
    "slideDeckVersion": {
      "minimum": 1,
      "title": "Slidedeckversion",
      "type": "integer"
    }
  },
  "required": [
    "schemaVersion",
    "projectId",
    "slideDeckVersion",
    "artifacts"
  ],
  "title": "RenderResult",
  "type": "object"
}
